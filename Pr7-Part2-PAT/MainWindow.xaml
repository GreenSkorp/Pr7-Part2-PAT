<Window x:Class="Pr7_Part2_PAT.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Pr7_Part2_PAT"
        mc:Ignorable="d"
        Title="MainWindow" Height="450" Width="800" Background="#dfeae9">
    <Window.Resources>
        <ResourceDictionary Source="/Style.xaml"/>
    </Window.Resources>
    <Grid>
        
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="2*"/>
        </Grid.RowDefinitions>

        <WrapPanel HorizontalAlignment="Center" VerticalAlignment="Center">
            <StackPanel Grid.Column="1" Grid.Row="0" VerticalAlignment="Center">
                <Button Content="Выход" Width="220" Height="40" Grid.Column="1" Style="{StaticResource PrimaryButton}" Margin="5"/>
                <Button Content="Очистить" Width="220" Height="40" Grid.Column="1" Style="{StaticResource PrimaryButton}" Margin="5"/>
            </StackPanel>
            <Border Style="{StaticResource GreyPanel}" Width="300" Height="90" >
                <StackPanel>
                <TextBlock Style="{StaticResource GreenBlock}" Text="Введите число сдвига:" HorizontalAlignment="Left"/>
                <TextBox Width="200" Height="30" Style="{StaticResource ModernTextBox}" HorizontalAlignment="Left" Margin="5"/>
                </StackPanel>
            </Border>

        <StackPanel Grid.Column="1" Grid.Row="0" VerticalAlignment="Center">
            <Button Content="Зашифровать" Width="220" Height="40" Grid.Column="1" Style="{StaticResource PrimaryButton}" Margin="5"/>
            <Button Content="Дешифровать" Width="220" Height="40" Grid.Column="1" Style="{StaticResource PrimaryButton}" Margin="5"/>
        </StackPanel>
        </WrapPanel>
        <Border Style="{StaticResource GreyPanel}" Grid.Column="0" Grid.Row="1" Margin="25" 
                MinHeight="100" Height="auto" 
                Width="auto" MinWidth="320">
            <WrapPanel HorizontalAlignment="Center">
                <StackPanel VerticalAlignment="Center" Margin="5 5 30 5">
                   <TextBlock Style="{StaticResource GreenBlock}" Text="Введите текст для обработки:" HorizontalAlignment="Left"/>
                   <TextBox Width="310" Height="130" Style="{StaticResource ModernTextBox}" HorizontalAlignment="Left" Margin="5"/>
                </StackPanel>

                <StackPanel VerticalAlignment="Center" Margin="15">
                    <TextBlock Style="{StaticResource GreenBlock}" Text="Результат:" HorizontalAlignment="Left"/>
                    <TextBox Width="310" Height="130" Style="{StaticResource ModernTextBox}" HorizontalAlignment="Left" Margin="5"/>
                </StackPanel>
            </WrapPanel>
        </Border>

    </Grid>
</Window>
